# ── Copy this file to .env and fill in real values ───────────────────────────
# .env is listed in .gitignore and must NEVER be committed.
#
# Each institution has its own PREFIXED env vars so settings never collide.

# ══════════════════════════════════════════════════════════════════════════════
# GEMINI (shared — used by the agent and crm.com.mk Vision extraction)
# ══════════════════════════════════════════════════════════════════════════════
GEMINI_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# Email (password reset)
# ══════════════════════════════════════════════════════════════════════════════

# Gmail address used as the sender.
SMTP_FROM_EMAIL=you@gmail.com

# Gmail App Password (generate at myaccount.google.com → Security → App passwords).
# Do NOT use your normal Gmail password here.
SMTP_APP_PASSWORD=

# Base URL of the frontend — used to build reset links in emails.
FRONTEND_URL=http://localhost:3000

# ══════════════════════════════════════════════════════════════════════════════
# uslugi.gov.mk
# ══════════════════════════════════════════════════════════════════════════════

# Base URL of the uslugi portal.
USLUGI_BASE_URL=https://uslugi.gov.mk

# "browser" (recommended — portal uses eid.mk SSO) or "http" (fallback).
USLUGI_AUTH_STRATEGY=browser

# Where to store the encrypted uslugi session cookies.
USLUGI_SESSION_FILE=storage/uslugi_session.enc

# ══════════════════════════════════════════════════════════════════════════════
# mojtermin.mk
# ══════════════════════════════════════════════════════════════════════════════

# Base URL of the mojtermin portal.
MOJTERMIN_BASE_URL=https://mojtermin.mk

# "browser" (safe default) or "http" (may work — portal has a standard login form).
MOJTERMIN_AUTH_STRATEGY=browser

# Login page URL (used by browser strategy as the starting URL).
MOJTERMIN_LOGIN_URL=https://mojtermin.mk/Account/Login

# Where to store the encrypted mojtermin session cookies.
MOJTERMIN_SESSION_FILE=storage/mojtermin_session.enc
