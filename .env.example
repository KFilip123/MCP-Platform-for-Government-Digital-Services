# ── Copy this file to .env and fill in real values ───────────────────────────
# .env is listed in .gitignore and must NEVER be committed.

# ------------------------------------------------------------------
# COOKIE ENCRYPTION KEY
# ------------------------------------------------------------------
# A Fernet symmetric key used to encrypt/decrypt session cookies on disk.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left empty the server will auto-generate a key on first run and
# print it here for you to persist manually.
COOKIE_ENCRYPTION_KEY=

# ------------------------------------------------------------------
# GEMINI API KEY
# ------------------------------------------------------------------
# Your Google AI Studio / Vertex AI key for Gemini Flash.
GEMINI_API_KEY=

# ------------------------------------------------------------------
# TARGET PORTAL
# ------------------------------------------------------------------
# Base URL of the portal we interact with.
PORTAL_BASE_URL=https://uslugi.gov.mk

# ------------------------------------------------------------------
# AUTH STRATEGY  ("browser" | "http")
# ------------------------------------------------------------------
# "browser"  → Playwright opens a real browser window so the user logs in
#              manually. Handles SSO, popups, 2FA, etc.
# "http"     → Attempts a direct HTTP POST login (may fail for portals that
#              use dynamic/JavaScript-driven auth). Kept as a fallback.
AUTH_STRATEGY=browser

# ------------------------------------------------------------------
# SESSION FILE PATH
# ------------------------------------------------------------------
# Where encrypted cookies are stored. Relative to the project root.
SESSION_FILE=storage/session.enc
